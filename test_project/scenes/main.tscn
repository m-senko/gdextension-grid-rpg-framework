[sub_resource type="GDScript" id="GDScript_0xm2m"]
script/source = "extends Node2D

@onready var player_inv: InventoryComponent = $Player/InventoryComponent
@onready var chest_inv: InventoryComponent = $Enemy/InventoryComponent

# Предзагружаем ресурсы предметов прямо в скрипт
const POTION_RESOURCE = preload(\"res://items/potion_health.tres\")
const SWORD_RESOURCE = preload(\"res://items/sword_iron.tres\")

func _ready() -> void:
	await get_tree().process_frame
	
	print(\"--- НАЧАЛО ТЕСТИРОВАНИЯ ДАННЫХ ИЗ РЕСУРСОВ ---\")
	
	player_inv.inventory_changed.connect(_on_player_inventory_changed)
	player_inv.weight_changed.connect(_on_player_weight_changed)
	
	# 1. Тест: Добавление стакающихся ресурсов через Godot Resource
	print(\"\\n[ТЕСТ 1] Добавление ресурсов игроку...\")
	player_inv.add_item(POTION_RESOURCE, 5)
	player_inv.add_item(POTION_RESOURCE, 3) # Должно схлопнуться в 8 шт.
	
	# 2. Тест: Добавление уникальных ресурсов
	player_inv.add_item(SWORD_RESOURCE, 1)
	player_inv.add_item(SWORD_RESOURCE, 1) # Займет два отдельных слота
	
	_print_inventory_debug(\"ИГРОК\", player_inv)

	# 3. Тест: Частичное удаление и сжатие плоского списка
	print(\"\\n[ТЕСТ 2] Игрок тратит 2 зелья...\")
	player_inv.remove_item(0, 2)
	_print_inventory_debug(\"ИГРОК\", player_inv)

	# 4. Тест: Атомарный трансфер между универсальными инвентарями
	print(\"\\n[ТЕСТ 3] Перекладываем меч в сундук...\")
	var success = player_inv.transfer_to(1, chest_inv, 1)
	print(\"Результат трансфера: \", success)
	
	_print_inventory_debug(\"ИГРОК ПОСЛЕ ТРАНСФЕРА\", player_inv)
	_print_inventory_debug(\"СУНДУК ПОСЛЕ ТРАНСФЕРА\", chest_inv)

func _print_inventory_debug(owner_name: String, inv: InventoryComponent) -> void:
	print(\"=== Инвентарь: %s (Вес: %s/%s) ===\" % [owner_name, inv.get_current_weight(), inv.get_max_weight()])
	var items = inv.get_items()
	for i in range(items.size()):
		var item: ItemInstance = items[i]
		# Доступ к данным теперь идет через объект шаблона .get_template()
		var template: ItemTemplate = item.get_template() 
		print(\" Слот [%d]: Название: %s (ID: %s) | Кол-во: %d | Общий вес: %s кг\" % [
			i, 
			template.item_name, 
			item.get_template_id(), 
			item.count, 
			item.get_total_weight()
		])
	print(\"=========================================\")

func _on_player_inventory_changed() -> void:
	print(\" -> [Сигнал UI]: Обновление интерфейса...\")

func _on_player_weight_changed(new_weight: float, max_weight: float) -> void:
	print(\" -> [Сигнал Веса]: Изменение массы: %.1f / %.1f кг\" % [new_weight, max_weight])
"

